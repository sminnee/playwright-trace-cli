{
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 120,
  "proseWrap": "always",
  "trailingComma": "all",
  "overrides": [
    {
      "files": "*.md",
      "options": {
        "printWidth": 100
      }
    },
    {
      "files": "skills/*/SKILL.md",
      "options": {
        "printWidth": 500
      }
    }
  ]
}
